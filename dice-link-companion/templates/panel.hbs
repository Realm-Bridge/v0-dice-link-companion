{{!-- Dice Link Companion Panel Template --}}
{{!-- Note: This template is prepared for future use. Currently the panel is rendered via JS. --}}

<div class="dlc-panel-container">
  {{!-- Header with logo --}}
  <div class="dlc-header">
    <a href="{{realmBridgeUrl}}" target="_blank" rel="noopener noreferrer" title="Visit Realm Bridge">
      <img src="{{logoUrl}}" alt="Realm Bridge" class="dlc-logo">
    </a>
  </div>

  {{!-- Settings Section --}}
  {{#if isGM}}
  <div class="dlc-section {{#if collapsed.topRow}}collapsed{{/if}}">
    <div class="dlc-section-header" data-section="topRow">
      <span class="dlc-collapse-btn">{{#if collapsed.topRow}}+{{else}}-{{/if}}</span>
      <h3><i class="fas fa-cog"></i> {{localize "DICE_LINK.Settings"}}</h3>
    </div>
    <div class="dlc-section-content">
      {{> settingsContent}}
    </div>
  </div>
  {{/if}}

  {{!-- Player Modes Section --}}
  {{#if isGM}}
  <div class="dlc-section {{#if collapsed.playerModes}}collapsed{{/if}}">
    <div class="dlc-section-header" data-section="playerModes">
      <span class="dlc-collapse-btn">{{#if collapsed.playerModes}}+{{else}}-{{/if}}</span>
      <h3><i class="fas fa-users"></i> {{localize "DICE_LINK.PlayerModes"}}</h3>
    </div>
    <div class="dlc-section-content">
      {{> playerModesContent}}
    </div>
  </div>
  {{/if}}

  {{!-- Roll Request Section --}}
  {{#if showRollRequest}}
  <div class="dlc-section dlc-roll-request-section {{#if hasPendingRoll}}dlc-roll-request-pending{{/if}} {{#if collapsed.rollRequest}}collapsed{{/if}}">
    <div class="dlc-section-header" data-section="rollRequest">
      <span class="dlc-collapse-btn">{{#if collapsed.rollRequest}}+{{else}}-{{/if}}</span>
      <h3>
        <i class="fas fa-dice-d20"></i> {{localize "DICE_LINK.RollRequest"}}
        {{#if hasPendingRoll}}<span class="dlc-pending-badge">PENDING</span>{{/if}}
      </h3>
    </div>
    <div class="dlc-section-content">
      {{#if hasPendingRoll}}
        {{> pendingRollContent}}
      {{else}}
        {{> diceTrayContent}}
      {{/if}}
    </div>
  </div>
  {{/if}}

  {{!-- Video Feed Section --}}
  <div class="dlc-section {{#if collapsed.videoFeed}}collapsed{{/if}}">
    <div class="dlc-section-header" data-section="videoFeed">
      <span class="dlc-collapse-btn">{{#if collapsed.videoFeed}}+{{else}}-{{/if}}</span>
      <h3><i class="fas fa-video"></i> {{localize "DICE_LINK.VideoFeed"}}</h3>
    </div>
    <div class="dlc-section-content">
      {{> videoFeedContent}}
    </div>
  </div>
</div>
