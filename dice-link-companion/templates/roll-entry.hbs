{{!-- Roll Entry Template - For manual dice value entry --}}
<div class="dlc-pending-roll dlc-dice-entry-step">
  <div class="dlc-pending-roll-header">
    <h4 class="dlc-pending-roll-title">{{title}}</h4>
    {{#if subtitle}}
    <p class="dlc-pending-roll-subtitle">{{subtitle}}</p>
    {{/if}}
  </div>
  
  <div class="dlc-dice-inputs">
    {{#each diceNeeded}}
    <div class="dlc-dice-input-row">
      <label class="dlc-dice-label">{{type}}</label>
      <input type="number" 
             class="dlc-dice-value-input" 
             data-die-index="{{@index}}" 
             data-die-faces="{{faces}}"
             min="1" 
             max="{{faces}}" 
             placeholder="1-{{faces}}">
    </div>
    {{/each}}
  </div>
  
  <div class="dlc-pending-roll-actions">
    <button type="button" class="dlc-roll-action-btn dlc-submit-dice-btn dlc-btn-success">
      {{localize "DICE_LINK.Roll.Submit"}}
    </button>
  </div>
  
  <div class="dlc-pending-roll-footer">
    <button type="button" class="dlc-roll-cancel-btn">
      {{localize "DICE_LINK.Roll.Cancel"}}
    </button>
  </div>
</div>
